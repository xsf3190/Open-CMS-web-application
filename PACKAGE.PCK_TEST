CREATE OR REPLACE EDITIONABLE PACKAGE "PCK_TEST" as
    --
    PROCEDURE test(pWebsiteid in number, pStatus OUT NUMBER);
end;
/
CREATE OR REPLACE EDITIONABLE PACKAGE BODY "PCK_TEST" as

    PROCEDURE test(pWebsiteid in number, pStatus OUT NUMBER) IS
    BEGIN
        pStatus:=200;

        EXCEPTION WHEN OTHERS THEN
            pck_core.log_error(pStatus);
    END;

end;
/