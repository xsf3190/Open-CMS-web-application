CREATE TABLE "LANGUAGE" 
   (	"CODE" VARCHAR2(2), 
	"UNICODE_RANGE" CLOB, 
	"URLENCODED" CLOB, 
	"CHARACTER_COUNT" NUMBER, 
	"CHARACTERS" CLOB, 
	"NAME" VARCHAR2(20), 
	 CONSTRAINT "PK_LANGUAGE" PRIMARY KEY ("CODE")
  USING INDEX  ENABLE
   ) ;

  CREATE UNIQUE INDEX "PK_LANGUAGE" ON "LANGUAGE" ("CODE") 
  ;